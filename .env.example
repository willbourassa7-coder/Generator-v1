# ============================================================================
# Environment Configuration Guide
# ============================================================================
# Copy this file to .env and replace placeholder values with your actual
# configuration. NEVER commit the actual .env file to version control as it
# contains sensitive information.
#
# For detailed setup instructions, see docs/SETUP.md
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (Required)
# ============================================================================
# PostgreSQL connection string for the main database
# Format: postgres://username:password@host:port/database
# Default: postgres://localhost:5432/generator_dev (for local development)
# Valid hosts: localhost, db (Docker), your-rds-endpoint.amazonaws.com
DATABASE_URL=postgres://username:password@db:5432/dbname

# ============================================================================
# CACHE CONFIGURATION (Required)
# ============================================================================
# Redis connection URL for caching and session storage
# Format: redis://[password@]host:port[/db_number]
# Default: redis://localhost:6379 (for local development)
# Valid hosts: localhost, cache (Docker), your-redis-endpoint.elasticache.amazonaws.com
REDIS_URL=redis://cache:6379

# ============================================================================
# API CONFIGURATION (Required)
# ============================================================================
# Your API key for external service authentication
# Keep this value secret and never commit it to version control
# Generate a new key from: https://your-api-provider.com/settings/keys
# Length: typically 32-64 characters
API_KEY=your_api_key_here

# ============================================================================
# APPLICATION ENVIRONMENT (Required)
# ============================================================================
# Valid values: development, production, test, staging
# Default: development
# - development: verbose logging, hot reload enabled, debug mode on
# - production: optimized performance, minimal logging, error handling strict
# - test: test-specific configurations, mock services enabled
# - staging: production-like environment for pre-release testing
NODE_ENV=development

# ============================================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================================
# Logging level for application output
# Default: info
# Valid values: error, warn, info, debug, trace
# - error: only errors
# - warn: errors and warnings
# - info: errors, warnings, and general info (recommended for production)
# - debug: includes detailed diagnostic information (recommended for development)
# - trace: most verbose output, includes all function calls
LOG_LEVEL=info

# ============================================================================
# PERFORMANCE CONFIGURATION (Optional)
# ============================================================================
# Request timeout in milliseconds
# Default: 5000 (5 seconds)
# Set higher for slow networks or long-running operations
TIMEOUT=5000

# Maximum concurrent database connections
# Default: 20
# Adjust based on your database plan and expected load
DB_POOL_SIZE=20

# ============================================================================
# OPTIONAL FEATURES (Uncomment to enable)
# ============================================================================
# Enable debug mode for verbose output and stack traces
# DEBUG=true

# Email service configuration (if your app sends emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# AWS S3 configuration (if your app uses file storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# JWT/Authentication configuration
# JWT_SECRET=your-jwt-secret-key-min-32-characters
# JWT_EXPIRY=24h

# ============================================================================
# SECURITY NOTES
# ============================================================================
# - Never commit the actual .env file to git (it's in .gitignore)
# - Rotate API keys and secrets regularly
# - Use strong, unique values for all secrets
# - Update credentials when team members leave
# - In production, use a secrets management service (AWS Secrets Manager, etc.)
# ============================================================================
